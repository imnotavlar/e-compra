<UserControl x:Class="Teste.View.EditarPerfilCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="ModernInputStyle" TargetType="Control">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border x:Name="border" 
                                CornerRadius="6" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource ModernInputStyle}"/>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource ModernInputStyle}"/>
    </UserControl.Resources>

    <Grid Margin="40,30,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Editar Perfil"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1E293B"
                   Margin="10,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.03" ShadowDepth="2" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Foto de Perfil" FontSize="15" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Ellipse Width="140" Height="140" Stroke="#F1F5F9" StrokeThickness="4">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="ImagemPerfil" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Button Content="Alterar Foto" Height="36" Width="130" Margin="0,16,0,0" Background="#3B82F6" Foreground="White" FontWeight="SemiBold" FontSize="13" Cursor="Hand" BorderThickness="0" Click="AlterarFoto_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="32" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.03" ShadowDepth="2" Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,10,0">

                            <TextBlock Text="Dados Pessoais" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                    <TextBlock Text="Nome Completo" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtNome" Text="{Binding Nome}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                                    <TextBlock Text="Telefone de Contato" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtTelefone" Text="{Binding Telefone}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Endereço de Email" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtEmail" Text="{Binding Email}"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#F1F5F9" Height="1" Margin="0,0,0,24"/>

                            <TextBlock Text="Endereço de Entrega" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                    <TextBlock Text="CEP" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtCEP" TextChanged="TxtCEP_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,12,16">
                                    <TextBlock Text="Rua / Logradouro" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtRua"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,16">
                                    <TextBlock Text="Número" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtNumero"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,12,0">
                                    <TextBlock Text="Bairro" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtBairro"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="0,24,0,0" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Cancelar" Height="40" Width="120" Margin="0,0,12,0" Background="#F1F5F9" Foreground="#475569" BorderThickness="0" FontWeight="SemiBold" FontSize="14" Cursor="Hand" Click="Cancelar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="1" Content="Salvar Alterações" Height="40" Width="160" Background="#FFD700" Foreground="#1E293B" BorderThickness="0" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="Salvar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>