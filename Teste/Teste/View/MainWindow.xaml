<Window x:Class="Teste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgInput" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BordaInputPadrao" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="BordaInputFoco" Color="#1E22D8"/>
        <SolidColorBrush x:Key="TextoPrimario" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextoSecundario" Color="#64748B"/>
        <SolidColorBrush x:Key="BotaoAcao" Color="#FFD700"/>
        <SolidColorBrush x:Key="BotaoAcaoHover" Color="#F2CC00"/>

        <Style x:Key="ModernInputStyle" TargetType="Control">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BordaInputPadrao}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border x:Name="TemplateBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TemplateBorder" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TemplateBorder" Property="BorderBrush" Value="{StaticResource BordaInputFoco}"/>
                                <Setter TargetName="TemplateBorder" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource ModernInputStyle}"/>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource ModernInputStyle}"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BotaoAcao}"/>
            <Setter Property="Foreground" Value="{StaticResource TextoPrimario}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Margin" Value="0,12,0,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BotaoAcaoHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" 
              Background="White" 
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch">

            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Width="400">

                <TextBlock Text="Crie sua conta"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextoPrimario}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Preencha os campos abaixo para começar."
                           FontSize="14"
                           Foreground="{StaticResource TextoSecundario}"
                           Margin="0,0,0,28"/>

                <TextBlock Text="Nome Completo" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextoSecundario}" 
                           Margin="0,0,0,6"/>
                <TextBox x:Name="NomeBox"/>

                <TextBlock Text="E-mail" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextoSecundario}" 
                           Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox"/>

                <TextBlock Text="Número de Telefone" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextoSecundario}" 
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TelefoneBox" MaxLength="11" PreviewTextInput="TelefoneBox_PreviewTextInput"/>

                <TextBlock Text="Senha" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextoSecundario}" 
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="SenhaBox"/>

                <TextBlock Text="Confirmar Senha" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextoSecundario}" 
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmarSenhaBox"/>

                <Button Content="Criar Conta" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Click="CriarConta_Click"/>

                <TextBlock HorizontalAlignment="Center" FontSize="14" Foreground="{StaticResource TextoSecundario}">
                    Já tem uma conta?
                    <Hyperlink Foreground="{StaticResource BordaInputFoco}" 
                               FontWeight="SemiBold"
                               Command="{Binding Path=IrParaLoginCommand}" 
                               Click="Entrar_Click" 
                               TextDecorations="None">
                        Entrar
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Grid>

        <Border Grid.Column="1"
                Background="#1E22D8"
                Padding="60">

            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">

                    <TextBlock
                               FontSize="28"
                               FontWeight="Black"
                               Foreground="White"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24" Text="🛒 E-Compra"/>

                    <TextBlock Text="Seja bem-vindo ao ecossistema de compras E-Compra."
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               LineHeight="46"/>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>