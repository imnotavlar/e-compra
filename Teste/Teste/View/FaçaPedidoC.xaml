<UserControl x:Class="CestaApp.Views.CestaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="av"
             Background="#F7F7F7" Width="790" Height="423">

	<!-- 🎨 RESOURCES -->
	<UserControl.Resources>

		<!-- Cores -->
		<SolidColorBrush x:Key="PrimaryColor" Color="#FFD700"/>
		<SolidColorBrush x:Key="CardBackground" Color="White"/>
		<SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
		<SolidColorBrush x:Key="TextPrimary" Color="#222"/>
		<SolidColorBrush x:Key="TextSecondary" Color="#666"/>

		<!-- Card -->
		<Style x:Key="CardStyle" TargetType="Border">
			<Setter Property="Background" Value="{StaticResource CardBackground}"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="15"/>
			<Setter Property="Margin" Value="5"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<!-- Botões quantidade -->
		<Style x:Key="QtyButtonStyle" TargetType="Button">
			<Setter Property="Width" Value="28"/>
			<Setter Property="Height" Value="28"/>
			<Setter Property="Margin" Value="2"/>
			<Setter Property="Background" Value="#F0F0F0"/>
			<Setter Property="BorderBrush" Value="#CCC"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>

		<!-- Botão principal -->
		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Height" Value="45"/>
			<Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Margin" Value="0,10,0,0"/>
		</Style>

		<!-- Navbar botão -->
		<Style x:Key="NavButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Margin" Value="10,0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>

		<!-- Botão ícone -->
		<Style x:Key="IconButtonStyle" TargetType="Button">
			<Setter Property="Width" Value="40"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="Background" Value="#F5F5F5"/>
			<Setter Property="BorderBrush" Value="#DDD"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>

		<!-- DataGrid clean -->
		<Style TargetType="DataGrid">
			<Setter Property="GridLinesVisibility" Value="None"/>
			<Setter Property="RowBackground" Value="White"/>
			<Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>

	</UserControl.Resources>

	<!-- 🧱 LAYOUT PRINCIPAL -->
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="70"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- 🔝 NAVBAR -->
		<Grid Grid.Row="0" Background="White">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Logo -->
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
				<TextBlock Text="🧺" FontSize="22" Margin="0,0,8,0"/>
				<TextBlock Text="Basic" FontSize="18" FontWeight="Bold"/>
			</StackPanel>

			<!-- Menu -->
			<StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

				<Button Content="Faça seu Pedido" Style="{StaticResource NavButtonStyle}"/>
				<Button Content="Assinatura" Style="{StaticResource NavButtonStyle}"/>
				<Button Content="Pedidos" Style="{StaticResource NavButtonStyle}"/>
				<Button Content="Sobre" Style="{StaticResource NavButtonStyle}"/>
				<Button Content="Contato" Style="{StaticResource NavButtonStyle}"/>

			</StackPanel>

			<!-- Ações -->
			<StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">

				<!-- Perfil -->
				<Button Style="{StaticResource IconButtonStyle}" Margin="0,0,10,0">
					<TextBlock Text="👤"/>
				</Button>

				<!-- Carrinho -->
				<Button Style="{StaticResource IconButtonStyle}">
					<Grid>
						<TextBlock Text="🛒"/>

						<Border Background="Red"
                                Width="16" Height="16"
                                CornerRadius="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
							<TextBlock Text="2"
                                       Foreground="White"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
					</Grid>
				</Button>

			</StackPanel>
		</Grid>

		<!-- 📦 CONTEÚDO -->
		<Grid Grid.Row="1" Margin="20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="3*" />
				<ColumnDefinition Width="2*" />
			</Grid.ColumnDefinitions>

			<!-- Imagem -->
			<Border Grid.Column="0" Style="{StaticResource CardStyle}">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Cesta Premium"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

					<Image Source="/Assets/cesta.png"
                           Height="180"
                           Stretch="Uniform"/>
				</StackPanel>
			</Border>

			<!-- Produtos -->
			<Border Grid.Column="1" Style="{StaticResource CardStyle}">
				<DataGrid ItemsSource="{Binding Produtos}"
                          AutoGenerateColumns="False">

					<DataGrid.Columns>

						<DataGridTextColumn Header="Qtd"
                                            Binding="{Binding QuantidadeFixa}"
                                            Width="60"/>

						<DataGridTextColumn Header="Produto"
                                            Binding="{Binding Nome}"
                                            Width="*"/>

						<DataGridTemplateColumn>
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right">

										<Button Content="-"
                                                Style="{StaticResource QtyButtonStyle}"
                                                Command="{Binding DataContext.DiminuirCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>

										<TextBlock Text="{Binding QuantidadeSelecionada}"
                                                   Margin="8,0"
                                                   VerticalAlignment="Center"/>

										<Button Content="+"
                                                Style="{StaticResource QtyButtonStyle}"
                                                Command="{Binding DataContext.AumentarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>

									</StackPanel>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>

					</DataGrid.Columns>
				</DataGrid>
			</Border>

			<!-- Resumo -->
			<StackPanel Grid.Column="2">

				<Border Style="{StaticResource CardStyle}">
					<StackPanel>
						<TextBlock Text="Total"/>
						<TextBlock Text="{Binding Total, StringFormat=R$ {0:F2}}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
					</StackPanel>
				</Border>

				<Border Style="{StaticResource CardStyle}">
					<StackPanel>
						<TextBlock Text="Observações"/>
						<TextBox Text="{Binding Observacoes}"
                                 Height="80"
                                 AcceptsReturn="True"/>
					</StackPanel>
				</Border>

				<Button Content="Adicionar ao Carrinho"
                        Style="{StaticResource PrimaryButtonStyle}"/>

			</StackPanel>

		</Grid>
	</Grid>
</UserControl>