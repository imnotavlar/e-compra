<UserControl x:Class="Teste.View.FacaSeuPedidoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">
    <UserControl.Resources>
        <Style x:Key="EcomButton" TargetType="Button">
            <Setter Property="Background" Value="#1E22D8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1519A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid MaxWidth="1240" HorizontalAlignment="Center" Margin="24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="12,35,12,20" HorizontalAlignment="Center">
                <TextBlock Text="Escolha sua cesta ideal" 
                           FontSize="30" 
                           FontWeight="Black" 
                           Foreground="#0F172A"
                           TextAlignment="Center"/>

                <TextBlock Text="Selecione as melhores combinações com os melhores preços do mercado." 
                           FontSize="15" 
                           Foreground="#64748B" 
                           Margin="0,4,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding ListaCestas}" HorizontalAlignment="Stretch" Margin="0,0,0,40">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="285" Margin="12" Background="White" CornerRadius="12" Padding="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.04"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="180"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="8" Margin="0,0,0,14" ClipToBounds="True">
                                    <Image Source="{Binding ImagemCompleta}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8"/>
                                </Border>

                                <TextBlock Grid.Row="1" Text="{Binding Nome}" FontSize="16" FontWeight="Bold" Foreground="#1E293B" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>

                                <TextBlock Grid.Row="2" Text="{Binding Itens.Count, StringFormat='\{0\} Itens'}" FontSize="13" FontWeight="Medium" Foreground="#94A3B8" Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="3" Text="{Binding Preco, StringFormat='R$ \{0:N2\}'}" FontSize="20" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,14"/>

                                <Button Grid.Row="4" Content="Comprar Agora" Style="{StaticResource EcomButton}" Click="ComprarCesta_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>