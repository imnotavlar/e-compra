<Window x:Class="Teste.View.DetalhesCestaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Itens da Cesta" Height="456" Width="470"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="#F3F4F6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="TituloCesta" Text="Cesta Econômica" FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
            <TextBlock Text="Lista de produtos incluídos:" Foreground="#6B7280" FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1">
            <ListView x:Name="ListaProdutosCesta" BorderThickness="0" Margin="0,0,8,10" RenderTransformOrigin="0.5,0.5">
                <ListView.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="-0.05"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </ListView.RenderTransform>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Qtd" DisplayMemberBinding="{Binding Quantidade}" Width="50"/>

                        <GridViewColumn Header="Produto" DisplayMemberBinding="{Binding Nome}" Width="160"/>
                        <GridViewColumn Header="Marca" DisplayMemberBinding="{Binding Marca}" Width="100"/>
                        <GridViewColumn Header="Peso" DisplayMemberBinding="{Binding Peso}" Width="80"/>
                        <GridViewColumn Header="Preco" DisplayMemberBinding="{Binding Preco}" Width="80"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Button Grid.Row="2" Content="Fechar" Background="#1E293B" Foreground="White" 
                BorderThickness="0" Padding="10" Margin="0,15,0,0" Cursor="Hand" Click="Fechar_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>