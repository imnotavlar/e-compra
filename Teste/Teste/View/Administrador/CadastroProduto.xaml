<UserControl x:Class="Teste.View.CadastroProduto" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             Background="#F3F4F6">

    <UserControl.Resources>
        <Style x:Key="InputCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E22D8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E32FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Cadastro de Produtos" FontSize="28" FontWeight="Bold" Foreground="#1F2937"/>
                <TextBlock Text="Preencha os dados abaixo para adicionar um novo item ao estoque." Foreground="#6B7280" FontSize="15" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Nome do Produto" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource InputCard}">
                                <TextBox x:Name="NomeProdutoBox" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#1F2937"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Marca" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource InputCard}">
                                <TextBox x:Name="MarcaBox" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#1F2937"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="Categoria" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource InputCard}" Padding="8,4">
                                <ComboBox x:Name="CategoriaBox" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#1F2937">
                                    <ComboBoxItem Content="Alimentos"/>
                                    <ComboBoxItem Content="Limpeza"/>
                                    <ComboBoxItem Content="Bebidas"/>
                                    <ComboBoxItem Content="Outros"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="Preço" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource InputCard}">
                                <TextBox x:Name="PrecoBox" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#1F2937"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Peso (Ex: 2L, 10Kg, 500G)" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource InputCard}">
                                <TextBox x:Name="PesoBox" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#1F2937"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="➕ Salvar Produto" Style="{StaticResource ModernButton}" Click="SalvarProduto_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Produtos Cadastrados" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                    <ListView x:Name="ListaProdutos" Height="250" BorderBrush="#D1D5DB" BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Nome" DisplayMemberBinding="{Binding Nome}" Width="160"/>
                                <GridViewColumn Header="Marca" DisplayMemberBinding="{Binding Marca}" Width="120"/>
                                <GridViewColumn Header="Categoria" DisplayMemberBinding="{Binding Categoria}" Width="120"/>
                                <GridViewColumn Header="Preço" DisplayMemberBinding="{Binding Preco}" Width="80"/>
                                <GridViewColumn Header="Peso" DisplayMemberBinding="{Binding Peso}" Width="80"/>

                                <GridViewColumn Header="Ações" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️ Editar" Background="#F59E0B" Foreground="White" BorderThickness="0" 
                            Padding="8,4" Margin="0,0,5,0" Cursor="Hand" Click="EditarProduto_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>

                                                <Button Content="🗑️" Background="#EF4444" Foreground="White" BorderThickness="0" 
                            Padding="8,4" Cursor="Hand" Click="ExcluirProduto_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>