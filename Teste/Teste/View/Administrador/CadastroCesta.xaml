<UserControl x:Class="Teste.View.CadastroCesta"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <UserControl.Resources>
        <Style x:Key="InputCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Montar Cestas Básicas" FontSize="28" FontWeight="Black" Foreground="#1F2937"/>
                <TextBlock Text="Gerencie as combinações de produtos e crie novas ofertas para seus clientes." Foreground="#6B7280" FontSize="15" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nome da Cesta" Foreground="#4B5563" FontWeight="Bold" FontSize="13"/>
                        <Border Style="{StaticResource InputCard}">
                            <TextBox x:Name="NomeCestaBox" BorderThickness="0" Background="Transparent" FontSize="14" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Imagem da Cesta" Foreground="#4B5563" FontWeight="Bold" FontSize="13"/>
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource InputCard}" Margin="0,0,10,0">
                                <TextBox x:Name="ImagemPathBox" BorderThickness="0" Background="Transparent" FontSize="13" IsReadOnly="True" VerticalAlignment="Center" Foreground="#9CA3AF"/>
                            </Border>

                            <Button Grid.Column="1" Content="📷 Selecionar" Background="#6366F1" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,0" Height="40" Cursor="Hand" Click="SelecionarImagem_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <Border Background="#F3F4F6" CornerRadius="12" Width="180" Height="130" Margin="0,0,0,15" HorizontalAlignment="Left" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Image x:Name="PreviewImagem" Stretch="Uniform" Margin="10"/>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preço Final da Cesta (R$)" Foreground="#4B5563" FontWeight="Bold" FontSize="13"/>
                            <TextBlock x:Name="TxtPrecoSugerido" Grid.Column="1" Text="Soma dos Itens: R$ 0,00" Foreground="#6B7280" FontSize="12" FontStyle="Italic" VerticalAlignment="Bottom"/>
                        </Grid>
                        <Border Style="{StaticResource InputCard}">
                            <TextBox x:Name="PrecoCestaBox" BorderThickness="0" Background="Transparent" FontSize="16" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                        </Border>

                        <Separator Margin="0,10,0,20" Background="#F1F5F9"/>

                        <TextBlock Text="Adicionar Produto do Estoque" Foreground="#4B5563" FontWeight="Bold" FontSize="13"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource InputCard}" Margin="0,0,10,0">
                                <ComboBox x:Name="ProdutosComboBox" BorderThickness="0" Background="Transparent" FontSize="14" VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Nome}" FontWeight="Bold"/>
                                                <TextBlock Text=" - " Foreground="#9CA3AF"/>
                                                <TextBlock Text="{Binding Marca}" Foreground="#6B7280" FontStyle="Italic"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource InputCard}" Margin="0,0,10,0" Background="White">
                                <Grid>
                                    <TextBlock Text="Qtd" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" VerticalAlignment="Top" Margin="2,-2,0,0"/>
                                    <TextBox x:Name="QuantidadeBox" Text="1" BorderThickness="0" Background="Transparent" FontSize="15" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2" Content="➕ Add" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,0" Height="40" Cursor="Hand" Click="AdicionarItem_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Composição da Cesta" Foreground="#1F2937" FontWeight="Bold" FontSize="15" Margin="0,0,0,15"/>

                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                            <ListView x:Name="ListaItensAtuais" Height="340" BorderThickness="0" Background="White">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Qtd" DisplayMemberBinding="{Binding Quantidade}" Width="45"/>
                                        <GridViewColumn Header="Produto" DisplayMemberBinding="{Binding Nome}" Width="160"/>
                                        <GridViewColumn Header="Marca" DisplayMemberBinding="{Binding Marca}" Width="160"/>
                                        <GridViewColumn Header="Peso/Tam" DisplayMemberBinding="{Binding Peso}" Width="70"/>
                                        <GridViewColumn Header="Preço" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Preco, StringFormat='R$ \{0:N2\}'}" HorizontalAlignment="Right"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Ação" Width="50">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✕" Background="Transparent" Foreground="#EF4444" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="RemoverItemDaCesta_Click"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <Button Content="💾 Salvar Cesta Completa" Background="#1E22D8" Foreground="White" FontWeight="Bold" FontSize="15" BorderThickness="0" Padding="0,15" Margin="0,20,0,0" Cursor="Hand" Click="SalvarCesta_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Cestas Disponíveis" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                        <ListView x:Name="ListaCestas" Height="280" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nome da Cesta" DisplayMemberBinding="{Binding Nome}" Width="280"/>
                                    <GridViewColumn Header="Valor de Venda" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Preco, StringFormat='R$ \{0:N2\}'}" FontWeight="Bold" Foreground="#1E22D8"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Ações de Gerenciamento" Width="240">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="👁️ Ver" Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="10,5" Margin="0,0,5,0" Cursor="Hand" Click="VerItens_Click">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    <Button Content="✏️ Editar" Background="#F59E0B" Foreground="White" BorderThickness="0" Padding="10,5" Margin="0,0,5,0" Cursor="Hand" Click="EditarCesta_Click">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    <Button Content="🗑️ Excluir" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="10,5" Cursor="Hand" Click="ExcluirCesta_Click">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>