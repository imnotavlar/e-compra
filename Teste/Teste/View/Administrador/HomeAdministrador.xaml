<UserControl x:Class="Teste.View.HomeAdministrador"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Painel de Controle"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock x:Name="BoasVindasTexto"
                       Text="Bem-vindo de volta! Monitoramento em tempo real das entregas e estoque."
                       FontSize="14"
                       Foreground="#64748B"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20,16" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Total de Pedidos Mês" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtPedidos" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20,16" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Cestas Prontas para Entrega" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtPedidosAEntregar" FontSize="32" FontWeight="Bold" Foreground="#3B82F6" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="8" Padding="20,16" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Aguardando Pagamento" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtPagPendentes" FontSize="32" FontWeight="Bold" Foreground="#EF4444" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Distribuição por Tipo de Cesta" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>

                    <ListBox Grid.Row="1" x:Name="ListaVendas" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,12"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Nome}" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="#E0F2FE" CornerRadius="12" Padding="12,4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Quantidade, StringFormat='\{0\} un'}" FontSize="13" FontWeight="Bold" Foreground="#0369A1"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Faturamento Bruto" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtFaturamento" FontSize="32" FontWeight="Black" Foreground="#10B981"/>

                        <TextBlock Text="Valores recebidos via PIX, dinheiro ou cartão." FontSize="12" Foreground="#94A3B8" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>