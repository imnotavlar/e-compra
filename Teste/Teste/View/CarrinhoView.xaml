<UserControl x:Class="CestaApp.Views.CarrinhoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.03" ShadowDepth="2" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#F2CC00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="40,30,40,40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,24,0">

            <DockPanel x:Name="PainelCarrinhoAtivo" Visibility="Visible">
                <TextBlock Text="Seu Carrinho de Compras" FontSize="26" FontWeight="Bold" Foreground="#0F172A" DockPanel.Dock="Top" Margin="0,0,0,24"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ItensNoCarrinho}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="#F1F5F9" Width="90" Height="90" CornerRadius="8" Margin="0,0,16,0" Padding="6">
                                            <Image Source="{Binding CestaSelecionada.ImagemCompleta}" Stretch="Uniform"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Quantidade, StringFormat='{}{0}x '}" FontWeight="Bold" FontSize="18" Foreground="#FFD700"/>
                                                <TextBlock Text="{Binding CestaSelecionada.Nome}" FontWeight="Bold" FontSize="18" Foreground="#1E293B"/>
                                            </StackPanel>

                                            <TextBlock Foreground="#475569" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0">
                                                <Run Text="Produtos inclusos: " FontWeight="SemiBold"/>
                                                <Run Text="{Binding ProdutosDetalhado, Mode=OneWay}"/>
                                            </TextBlock>

                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="Obs: " FontWeight="Bold" Foreground="#B91C1C" FontSize="13"/>
                                                <TextBlock Text="{Binding Observacoes}" Foreground="#B91C1C" FontStyle="Italic" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Grid.Column="2" VerticalAlignment="Stretch">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Subtotal, StringFormat='R$ {0:N2}', Mode=OneWay}" FontWeight="Bold" FontSize="18" Foreground="#0F172A" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                            <Button Grid.Row="1" Content="Remover" Background="Transparent" Foreground="#EF4444" FontWeight="SemiBold" FontSize="13" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="RemoverItem_Click"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <Border x:Name="PainelCarrinhoVazio" 
                    Style="{StaticResource CardStyle}" 
                    Visibility="Collapsed" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Padding="40,50" 
                    MaxWidth="500">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🛍️" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Seu carrinho está vazio" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#1E293B" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Parece que você ainda não escolheu seus produtos. Explore nossa loja e descubra as melhores cestas prontas para você!" 
                               FontSize="14" 
                               Foreground="#64748B" 
                               TextAlignment="Center" 
                               TextWrapping="Wrap" 
                               LineHeight="20"
                               Margin="0,0,0,28"/>

                    <Button Content="Voltar para a Loja" 
                            Style="{StaticResource ModernButtonStyle}" 
                            Width="200"
                            Click="VoltarParaLoja_Click"/>
                </StackPanel>
            </Border>

        </Grid>

        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="Resumo do Pedido" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,24"/>

                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Subtotal Itens" FontSize="14" Foreground="#64748B" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ValorTotal, StringFormat='R$ {0:N2}', Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Frete de Entrega" FontSize="14" Foreground="#64748B" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="Grátis" FontSize="14" FontWeight="SemiBold" Foreground="#22C55E" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Background="#E2E8F0" Height="1" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="Total:" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalGeral" Text="{Binding ValorTotal, StringFormat='R$ {0:N2}', Mode=OneWay}" FontSize="24" FontWeight="Black" Foreground="#1E22D8" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button x:Name="BtnFinalizar" 
                            Content="Finalizar Pedido" 
                            Style="{StaticResource ModernButtonStyle}"
                            Click="FinalizarPedido_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>